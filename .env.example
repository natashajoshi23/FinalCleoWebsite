# Resend — use a send-only API key (no read/admin scopes)
RESEND_API_KEY=re_...

# Sanity — public vars (safe to expose to browser)
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2026-06-11

# Sanity write token — NEVER expose to the browser; server-side only
# SANITY_API_WRITE_TOKEN=sk...
